# Blansole Backend - local development environment
# Copy this file to .env and fill in external service credentials as needed.

# App
NODE_ENV=development
API_PORT=3000
NGINX_HTTP_PORT=8081
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:8081
API_PUBLIC_URL=http://localhost:8081/api/v1
PUBLIC_API_HOST=localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# PostgreSQL + pgvector
POSTGRES_USER=blansole
POSTGRES_PASSWORD=blansole
POSTGRES_DB=blansole
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://blansole:blansole@localhost:5432/blansole
DOCKER_DATABASE_URL=postgresql://blansole:blansole@postgres:5432/blansole

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379
DOCKER_REDIS_HOST=redis
DOCKER_REDIS_URL=redis://redis:6379

# Object storage (MinIO / S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
DOCKER_S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=blansole-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# JWT / Auth
JWT_ACCESS_SECRET=CHANGE_ME_DEV_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_DEV_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth providers
GOOGLE_CLIENT_ID=
# Optional comma-separated mobile/web client ids; takes precedence together with GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback
APPLE_CLIENT_ID=
# Optional comma-separated bundle/service ids.
APPLE_CLIENT_IDS=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AI / embeddings
LLM_PROVIDER=openai
LLM_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=50
RAG_TOP_K=3
RAG_MAX_COSINE_DISTANCE=0.45
OPENAI_TIMEOUT_SECONDS=60
AI_WORKER_CONCURRENCY=2

# Content / YouTube
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Push notification
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_ENV=sandbox

# Admin bootstrap
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
