{
  "name": "blansole-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Blansole Smart Insole Health App — Backend Monorepo",
  "workspaces": [
    "apps/api",
    "apps/worker-session",
    "apps/worker-notification",
    "apps/worker-health-sync",
    "apps/worker-link-checker",
    "apps/worker-episode-summary",
    "libs/shared"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','libs/shared/dist']) fs.rmSync(p,{recursive:true,force:true});\"",
    "build": "npm run clean && npm run build:shared && npm run build:api && npm run build:worker-session && npm run build:worker-notification && npm run build:worker-health-sync && npm run build:worker-link-checker && npm run build:worker-episode-summary",
    "build:shared": "node ./node_modules/@nestjs/cli/bin/nest.js build shared",
    "build:api": "node ./node_modules/@nestjs/cli/bin/nest.js build api",
    "build:worker-session": "node ./node_modules/@nestjs/cli/bin/nest.js build worker-session",
    "build:worker-notification": "node ./node_modules/@nestjs/cli/bin/nest.js build worker-notification",
    "build:worker-health-sync": "node ./node_modules/@nestjs/cli/bin/nest.js build worker-health-sync",
    "build:worker-link-checker": "node ./node_modules/@nestjs/cli/bin/nest.js build worker-link-checker",
    "build:worker-episode-summary": "node ./node_modules/@nestjs/cli/bin/nest.js build worker-episode-summary",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start api --watch",
    "start:dev:worker-session": "node ./node_modules/@nestjs/cli/bin/nest.js start worker-session --watch",
    "start:debug": "node ./node_modules/@nestjs/cli/bin/nest.js start api --debug --watch",
    "start:prod:api": "node dist/apps/api/main.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"{apps,libs}/**/*.ts\"",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js \"{apps,libs}/**/*.ts\" --fix",
    "test": "node ./node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:cov": "node ./node_modules/jest/bin/jest.js --coverage",
    "test:e2e": "node ./node_modules/jest/bin/jest.js --config apps/api/test/jest-e2e.json",
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate:dev": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:studio": "node ./node_modules/prisma/build/index.js studio",
    "db:seed": "node -r ts-node/register prisma/seed.ts",
    "docker:dev": "docker compose -f infra/docker-compose.yml up -d",
    "docker:dev:down": "docker compose -f infra/docker-compose.yml down"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sanitize-html": "^2.17.6",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
