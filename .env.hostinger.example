# Blansole Hostinger VPS environment example
# Copy this file to .env on the Hostinger VPS and replace all CHANGE_ME values.

NODE_ENV=production
API_PORT=3000
NGINX_HTTP_PORT=80
LOG_LEVEL=info

APP_BASE_URL=https://api.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com/api/v1
PUBLIC_API_HOST=api.yourdomain.com
SSL_EMAIL=you@example.com
CORS_ORIGINS=https://api.yourdomain.com

POSTGRES_USER=CHANGE_ME_POSTGRES_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=blansole
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_STRONG_POSTGRES_PASSWORD@localhost:5432/blansole
DOCKER_DATABASE_URL=postgresql://CHANGE_ME_POSTGRES_USER:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/blansole

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379
DOCKER_REDIS_HOST=redis
DOCKER_REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=CHANGE_ME_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_ROOT_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
DOCKER_S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=blansole-prod
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_FORCE_PATH_STYLE=true

JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_STRONG_RANDOM_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/facebook/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

LLM_PROVIDER=openai
LLM_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_ENV=production

ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
